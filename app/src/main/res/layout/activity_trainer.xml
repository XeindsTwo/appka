<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/fitbook_background">

    <!-- Р В Р’В Р РҶР вҖҡРІвҖһСһР В Р’В Р вҖҷР’ВөР В Р РӢР В РІРӮСҷР В Р РӢР РҶР вҖҡР’ВҰР В Р’В Р В РІРӮВҰР В Р РӢР В Р РҸР В Р РӢР В Р РҸ Р В Р’В Р РҺРІРӮвҖқР В Р’В Р вҖҷР’В°Р В Р’В Р В РІРӮВҰР В Р’В Р вҖҷР’ВөР В Р’В Р вҖҷР’В»Р В Р РӢР В Р вҖ° Р В Р РӢР В РЎвҖң Р В Р’В Р РҺРІРӮвҖңР В Р РӢР В РІРӮСҷР В Р’В Р вҖҷР’В°Р В Р’В Р СһРІРӮВҳР В Р’В Р РҺРІРӮВҳР В Р’В Р вҖҷР’ВөР В Р’В Р В РІРӮВҰР В Р РӢР РҶР вҖҡРЎв„ўР В Р’В Р РҺРІРӮСһР В Р’В Р РҺР’Вҳ -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@color/fitbook_primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        android:paddingTop="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trainer_dashboard_title"
                android:fontFamily="sans-serif"
                android:textColor="@color/fitbook_text_on_accent"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvTrainerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trainer_role_label"
                android:fontFamily="sans-serif"
                android:textColor="@color/fitbook_text_on_accent"
                android:textSize="22sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <TextView
            android:id="@+id/btnOpenProfile"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp"
            android:background="@drawable/dashboard_card_tint"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="@string/settings_button"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="22sp" />
    </androidx.appcompat.widget.Toolbar>

    <!-- Р В Р’В Р РҺРІРӮС”Р В Р РӢР В РЎвҖңР В Р’В Р В РІРӮВҰР В Р’В Р РҺРІРӮСһР В Р’В Р В РІРӮВ Р В Р’В Р В РІРӮВҰР В Р’В Р РҺРІРӮСһР В Р’В Р РҶРІРӮСӣРІРӮвҖң Р В Р’В Р РҺРІРӮСңР В Р’В Р РҺРІРӮСһР В Р’В Р В РІРӮВҰР В Р РӢР РҶР вҖҡРЎв„ўР В Р’В Р вҖҷР’ВөР В Р’В Р В РІРӮВҰР В Р РӢР РҶР вҖҡРЎв„ў (Р В Р’В Р вҖҷР’ВұР В Р’В Р вҖҷР’ВөР В Р’В Р вҖҷР’В· ScrollView) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Р В Р’В Р РҺРІвҖһСһР В Р’В Р В РІРӮВҰР В Р’В Р РҺРІРӮСһР В Р’В Р РҺРІРӮвҖқР В Р’В Р РҺРІРӮСңР В Р’В Р РҺРІРӮВҳ Р В Р РӢР РҺРІРӮСҡР В Р’В Р РҺРІРӮвҖқР В Р РӢР В РІРӮСҷР В Р’В Р вҖҷР’В°Р В Р’В Р В РІРӮВ Р В Р’В Р вҖҷР’В»Р В Р’В Р вҖҷР’ВөР В Р’В Р В РІРӮВҰР В Р’В Р РҺРІРӮВҳР В Р РӢР В Р РҸ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:id="@+id/btnMySchedule"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/card_button_bg"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trainer_schedule_icon"
                    android:textSize="24sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trainer_schedule_title"
                    android:textSize="10sp"
                    android:textColor="#1A1A2E"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnMyClients"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/card_button_bg"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trainer_clients_icon"
                    android:textSize="24sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trainer_clients_title"
                    android:textSize="10sp"
                    android:textColor="#1A1A2E"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnAssignPlan"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/card_button_bg"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trainer_plan_icon"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trainer_plan_title"
                android:textSize="11sp"
                android:textColor="#1A1A2E"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Р В Р’В Р РҶР вҖҡРІРӮСңР В Р’В Р вҖҷР’В°Р В Р’В Р РҺРІРӮвҖңР В Р’В Р РҺРІРӮСһР В Р’В Р вҖҷР’В»Р В Р’В Р РҺРІРӮСһР В Р’В Р В РІРӮВ Р В Р’В Р РҺРІРӮСһР В Р’В Р РҺРІРӮСң -->
        <TextView
            android:id="@+id/tvSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/trainer_manage_title"
            android:fontFamily="sans-serif"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- ListView -->
        <ListView
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/card_list_bg"
            android:padding="8dp"
            android:divider="@android:color/transparent"
            android:dividerHeight="8dp"
            android:scrollbars="vertical"/>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@color/fitbook_surface"
        app:itemIconTint="@color/fitbook_primary"
        app:itemTextColor="@color/fitbook_text_primary"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/menu_trainer_bottom" />
</LinearLayout>
