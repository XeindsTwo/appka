<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitbook_background"
    android:orientation="vertical"
    tools:context=".TrainerActivity"
    tools:theme="@style/Theme.FitBook">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@color/fitbook_primary"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="32dp"
        android:paddingEnd="22dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/btnOpenProfile"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_gravity="end"
            android:background="@drawable/dashboard_card_tint"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:text="@string/settings_button"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/tvTrainerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:textColor="@color/fitbook_text_on_accent"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="Тренер Иван Петров" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSectionTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="18dp"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:text="@string/trainer_schedule_title"
        android:textColor="@color/fitbook_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="18dp"
        android:columnCount="2"
        android:useDefaultMargins="false">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMySchedule"
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_columnWeight="1"
            android:layout_marginEnd="7dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/fitbook_surface_light"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/fitbook_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/trainer_schedule_title"
                    android:src="@android:drawable/ic_menu_month"
                    android:tint="@color/fitbook_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/trainer_schedule_title"
                    android:textColor="@color/fitbook_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMyClients"
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_columnWeight="1"
            android:layout_marginStart="7dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="@color/fitbook_surface_light"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/fitbook_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@string/trainer_clients_title"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:tint="@color/fitbook_primary" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/trainer_clients_title"
                    android:textColor="@color/fitbook_text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </GridLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnAssignPlan"
        android:layout_width="match_parent"
        android:layout_height="104dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginBottom="14dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/fitbook_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/fitbook_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/trainer_plan_title"
                android:src="@android:drawable/ic_menu_edit"
                android:tint="@color/fitbook_primary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/trainer_plan_title"
                android:textColor="@color/fitbook_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="Планируй тренировки и дополняй упражнения своим клиентам"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <ListView
        android:id="@+id/listView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_weight="1"
        android:background="@android:color/transparent"
        android:cacheColorHint="@android:color/transparent"
        android:clipToPadding="false"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:paddingBottom="16dp"
        android:scrollbars="vertical" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@color/fitbook_surface"
        app:itemIconTint="@color/fitbook_primary"
        app:itemTextColor="@color/fitbook_text_primary"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_trainer_bottom" />
</LinearLayout>
