<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitbook_background"
    android:orientation="vertical"
    tools:context=".ContactsActivity"
    tools:theme="@style/Theme.FitBook">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:background="@color/fitbook_primary">

                <TextView
                    android:id="@+id/btnContactsBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="18dp"
                    android:layout_marginTop="42dp"
                    android:background="@drawable/dashboard_card_tint"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:text="@string/profile_back"
                    android:textColor="@color/fitbook_text_primary"
                    android:textSize="22sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingEnd="22dp">

                    <TextView
                        android:id="@+id/tvContactsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:includeFontPadding="false"
                        android:textColor="@color/fitbook_text_on_accent"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        tools:text="Контакты клуба" />

                    <TextView
                        android:id="@+id/tvContactsSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/inter"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:textColor="#CC171717"
                        android:textSize="13sp"
                        tools:text="Адрес, связь и карта фитнес-клуба" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/fitbook_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/inter"
                            android:includeFontPadding="false"
                            android:text="@string/client_contacts_address"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:fontFamily="@font/inter"
                            android:includeFontPadding="false"
                            android:text="@string/client_contacts_subtitle"
                            android:textColor="@color/fitbook_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnCall"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/fitbook_surface_light"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/fitbook_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:contentDescription="@string/client_contacts_call"
                                android:src="@android:drawable/ic_menu_call"
                                android:tint="@color/fitbook_primary" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:maxLines="2"
                                android:text="@string/client_contacts_call"
                                android:textColor="@color/fitbook_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnVk"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/fitbook_surface_light"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/fitbook_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_gravity="center"
                                android:background="@drawable/vk_badge_bg"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:text="VK"
                                android:textColor="@color/fitbook_text_on_accent"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="@string/client_contacts_vk"
                                android:textColor="@color/fitbook_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnMax"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="108dp"
                        android:layout_marginEnd="7dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/fitbook_surface_light"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/fitbook_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_gravity="center"
                                android:background="@drawable/max_badge_bg"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:text="MAX"
                                android:textColor="@color/fitbook_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="@string/client_contacts_max"
                                android:textColor="@color/fitbook_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnChat"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:minHeight="108dp"
                        android:layout_marginStart="7dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="@color/fitbook_surface_light"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/fitbook_stroke"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:layout_width="42dp"
                                android:layout_height="42dp"
                                android:layout_gravity="center"
                                android:background="@drawable/vk_badge_bg"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:text="VK"
                                android:textColor="@color/fitbook_text_on_accent"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:fontFamily="@font/inter"
                                android:gravity="center"
                                android:includeFontPadding="false"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:text="@string/client_contacts_chat"
                                android:textColor="@color/fitbook_text_primary"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/inter"
                    android:includeFontPadding="false"
                    android:text="@string/client_contacts_map"
                    android:textColor="@color/fitbook_text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <WebView
                    android:id="@+id/webMap"
                    android:layout_width="match_parent"
                    android:layout_height="280dp"
                    android:layout_marginTop="12dp"
                    android:background="@color/fitbook_surface"
                    android:overScrollMode="never" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
