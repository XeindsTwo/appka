<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="➕ Добавление упражнений"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="16dp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="#F5F5F5">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Добавить упражнение"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etExerciseName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Название упражнения"
            android:inputType="text"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <EditText
                android:id="@+id/etSets"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Подходы"
                android:inputType="number"
                android:text="3"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etReps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Повторения"
                android:inputType="number"
                android:text="12"
                android:padding="12dp"
                android:background="@android:drawable/editbox_background"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etWeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Рекомендуемый вес (кг)"
            android:inputType="numberDecimal"
            android:text="50"
            android:padding="12dp"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAddExercise"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="➕ Добавить в план"
            android:backgroundTint="#4CAF50"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Упражнения в плане:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#F5F5F5"
        android:padding="8dp">

        <TextView
            android:id="@+id/tvExercisesList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Пока нет упражнений"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"/>
    </ScrollView>

    <Button
        android:id="@+id/btnFinish"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Завершить и сохранить план"
        android:backgroundTint="#2196F3"
        android:layout_marginTop="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Добавляйте упражнения одно за другим"
        android:textSize="11sp"
        android:textColor="#757575"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

</LinearLayout>

