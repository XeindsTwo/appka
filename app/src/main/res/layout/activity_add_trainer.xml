<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitbook_background">

    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/footerActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="Добавление тренера"
                android:textColor="@color/fitbook_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="Отдельный экран для создания сотрудника"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="ФИО тренера"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.FitBook.LoginTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:autofillHints="name"
                    android:fontFamily="@font/inter"
                    android:hint="Введите ФИО тренера"
                    android:importantForAutofill="yes"
                    android:inputType="textPersonName"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:singleLine="true"
                    android:textColor="@color/fitbook_text_primary"
                    android:textColorHint="@color/fitbook_text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="Телефон"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.FitBook.LoginTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:autofillHints="phone"
                    android:fontFamily="@font/inter"
                    android:hint="Введите телефон"
                    android:importantForAutofill="yes"
                    android:inputType="phone"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:singleLine="true"
                    android:textColor="@color/fitbook_text_primary"
                    android:textColorHint="@color/fitbook_text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="Email"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.FitBook.LoginTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:autofillHints="emailAddress"
                    android:fontFamily="@font/inter"
                    android:hint="Введите email"
                    android:importantForAutofill="yes"
                    android:inputType="textEmailAddress"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:singleLine="true"
                    android:textColor="@color/fitbook_text_primary"
                    android:textColorHint="@color/fitbook_text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="Специализация"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.FitBook.LoginTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:endIconMode="dropdown_menu"
                app:hintEnabled="false">

                <com.google.android.material.textfield.MaterialAutoCompleteTextView
                    android:id="@+id/etSpecialization"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:fontFamily="@font/inter"
                    android:hint="Выберите специализацию"
                    android:inputType="text"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:textColor="@color/fitbook_text_primary"
                    android:textColorHint="@color/fitbook_text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="Опыт (лет)"
                android:textColor="@color/fitbook_text_secondary"
                android:textSize="11sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.FitBook.LoginTextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etExperience"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:autofillHints="none"
                    android:fontFamily="@font/inter"
                    android:hint="Введите количество лет"
                    android:inputType="number"
                    android:minHeight="58dp"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:singleLine="true"
                    android:textColor="@color/fitbook_text_primary"
                    android:textColorHint="@color/fitbook_text_hint"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/footerActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:fontFamily="@font/inter"
            android:text="Создать тренера"
            android:textAllCaps="false"
            android:textColor="@color/fitbook_text_on_accent"
            android:textStyle="bold"
            app:backgroundTint="@color/fitbook_primary"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter"
            android:text="Отменить создание"
            android:textAllCaps="false"
            android:textColor="@color/colorDanger"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:strokeColor="@color/colorDanger"
            app:strokeWidth="1dp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
