<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".LoginActivity"
    tools:theme="@style/Theme.FitBook">

    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@color/fitbook_primary"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp">

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:lineSpacingExtra="4dp"
            android:text="@string/app_name"
            android:textColor="@color/fitbook_text_on_accent"
            android:textSize="38sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHeaderSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:lineSpacingExtra="3dp"
            android:text="@string/login_subtitle"
            android:textColor="#D8171717"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/loginForm"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/fitbook_background"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="30dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="3dp"
            android:text="@string/login_title"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="@string/login_hint"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:autofillHints="username"
                android:fontFamily="@font/inter"
                android:hint="Введите логин"
                android:importantForAutofill="yes"
                android:inputType="text"
                android:minHeight="58dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="@string/password_hint"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:endIconMode="password_toggle"
            app:endIconTint="@color/fitbook_primary"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:autofillHints="password"
                android:fontFamily="@font/inter"
                android:hint="Введите пароль"
                android:importantForAutofill="yes"
                android:inputType="textPassword"
                android:minHeight="58dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            tools:ignore="NestedWeights" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:fontFamily="@font/inter"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/login_button"
            android:textAllCaps="false"
            android:textColor="@color/fitbook_text_on_accent"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/fitbook_primary"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowRegister"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/register_button"
            android:textAllCaps="false"
            android:textColor="@color/fitbook_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="22dp"
            app:strokeColor="@color/fitbook_primary"
            app:strokeWidth="1dp" />
    </LinearLayout>
</LinearLayout>
