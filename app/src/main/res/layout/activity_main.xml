<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitbook_background"
    tools:context=".MainActivity"
    tools:theme="@style/Theme.FitBook">

    <LinearLayout
        android:id="@+id/splashContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/logoCard"
            android:layout_width="112dp"
            android:layout_height="112dp"
            app:cardBackgroundColor="@color/fitbook_primary"
            app:cardCornerRadius="32dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/inter"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/splash_logo_mark"
                android:textColor="@color/fitbook_text_on_accent"
                android:textSize="34sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvSplashTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="4dp"
            android:text="@string/app_name"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="42sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvSplashSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:includeFontPadding="false"
            android:lineSpacingExtra="5dp"
            android:text="@string/splash_subtitle"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="15sp" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/loadingIndicator"
            android:layout_width="180dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="42dp"
            android:indeterminate="true"
            app:indicatorColor="@color/fitbook_primary"
            app:trackColor="@color/fitbook_surface_light"
            app:trackCornerRadius="4dp"
            app:trackThickness="6dp" />

        <TextView
            android:id="@+id/tvLoadingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/splash_loading"
            android:textColor="@color/fitbook_text_hint"
            android:textSize="13sp" />
    </LinearLayout>

    <View
        android:id="@+id/accentGlow"
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_gravity="bottom"
        android:background="@color/fitbook_primary" />
</FrameLayout>
