<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitbook_background"
    android:orientation="vertical"
    tools:context=".AdminActivity"
    tools:theme="@style/Theme.FitBook">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/headerContainer"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:background="@color/fitbook_primary"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="32dp"
                android:paddingEnd="22dp"
                android:paddingBottom="24dp">

                <TextView
                    android:id="@+id/btnOpenProfile"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="end"
                    android:background="@drawable/dashboard_card_tint"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:text="@string/settings_button"
                    android:textColor="@color/fitbook_text_primary"
                    android:textSize="22sp" />

                <TextView
                    android:id="@+id/tvAdminName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:fontFamily="@font/inter"
                    android:includeFontPadding="false"
                    android:text="Администрирование клубом"
                    android:textColor="@color/fitbook_text_on_accent"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    tools:text="Администрирование клубом" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="18dp"
                android:fontFamily="@font/inter"
                android:includeFontPadding="false"
                android:text="@string/admin_dashboard_title"
                android:textColor="@color/fitbook_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="18dp"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAddTrainer"
                    android:layout_width="match_parent"
                    android:layout_height="132dp"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/admin_add_trainer"
                            android:src="@android:drawable/ic_input_add"
                            android:tint="@color/fitbook_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_add_trainer"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_add_trainer_hint"
                            android:textColor="@color/fitbook_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnAddSchedule"
                    android:layout_width="match_parent"
                    android:layout_height="132dp"
                    android:layout_marginBottom="14dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/admin_add_schedule"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            android:tint="@color/fitbook_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_add_schedule"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_add_schedule_hint"
                            android:textColor="@color/fitbook_text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="18dp"
                android:columnCount="2"
                android:useDefaultMargins="false">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewClients"
                    android:layout_width="0dp"
                    android:layout_height="122dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="7dp"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface_light"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:contentDescription="@string/admin_view_clients"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:tint="@color/fitbook_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_view_clients"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewTrainers"
                    android:layout_width="0dp"
                    android:layout_height="122dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="7dp"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface_light"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:contentDescription="@string/admin_view_trainers"
                            android:src="@android:drawable/ic_menu_slideshow"
                            android:tint="@color/fitbook_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_view_trainers"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnViewSchedule"
                    android:layout_width="0dp"
                    android:layout_height="122dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="7dp"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface_light"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:contentDescription="@string/admin_view_schedule"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:tint="@color/fitbook_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_view_schedule"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMembershipTypes"
                    android:layout_width="0dp"
                    android:layout_height="122dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="7dp"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface_light"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:contentDescription="@string/admin_membership_types"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            android:tint="@color/fitbook_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:fontFamily="@font/inter"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="@string/admin_membership_types"
                            android:textColor="@color/fitbook_text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnRegisterClient"
                    android:layout_width="match_parent"
                    android:layout_height="122dp"
                    android:layout_columnSpan="2"
                    android:layout_marginBottom="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/fitbook_surface"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/fitbook_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:contentDescription="@string/admin_register_client"
                            android:src="@android:drawable/ic_input_add"
                            android:tint="@color/fitbook_primary" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="14dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/inter"
                                android:includeFontPadding="false"
                                android:text="@string/admin_register_client"
                                android:textColor="@color/fitbook_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:fontFamily="@font/inter"
                                android:includeFontPadding="false"
                                android:text="@string/admin_register_client_hint"
                                android:textColor="@color/fitbook_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </GridLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddMembership"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="18dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="18dp"
                android:fontFamily="@font/inter"
                android:text="@string/admin_add_membership"
                android:textAllCaps="false"
                android:textColor="@color/fitbook_text_on_accent"
                android:textStyle="bold"
                app:backgroundTint="@color/fitbook_primary"
                app:cornerRadius="24dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/clientFilterContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_marginTop="14dp"
                android:layout_marginEnd="18dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/fitbook_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/fitbook_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:includeFontPadding="false"
                        android:text="Фильтры клиентов"
                        android:textColor="@color/fitbook_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter"
                        android:includeFontPadding="false"
                        android:text="Удобно искать по тренеру и статусу абонемента"
                        android:textColor="@color/fitbook_text_secondary"
                        android:textSize="12sp" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.FitBook.LoginTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etClientSearch"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:hint="Поиск по имени, логину или телефону"
                            android:inputType="text"
                            android:imeOptions="actionSearch"
                            android:textColor="@color/fitbook_text_primary"
                            android:textColorHint="@color/fitbook_text_hint" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.FitBook.LoginTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:hintEnabled="false">

                        <Spinner
                            android:id="@+id/spinnerClientTrainerFilter"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.FitBook.LoginTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:hintEnabled="false">

                        <Spinner
                            android:id="@+id/spinnerClientMembershipFilter"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.FitBook.LoginTextInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        app:hintEnabled="false">

                        <Spinner
                            android:id="@+id/spinnerClientSort"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetClientFilters"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/inter"
                        android:text="Сбросить фильтры"
                        android:textAllCaps="false"
                        android:textColor="@color/fitbook_primary"
                        app:backgroundTint="@color/fitbook_surface_light"
                        app:cornerRadius="18dp"
                        app:strokeColor="@color/fitbook_primary"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <ListView
                android:id="@+id/listView"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginStart="18dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/card_list_bg"
                android:divider="@android:color/transparent"
                android:dividerHeight="8dp"
                android:padding="8dp"
                android:scrollbars="vertical" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="66dp"
        android:background="@color/fitbook_surface"
        app:itemIconTint="@color/fitbook_primary"
        app:itemTextColor="@color/fitbook_text_primary"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/menu_admin_bottom" />
</LinearLayout>
