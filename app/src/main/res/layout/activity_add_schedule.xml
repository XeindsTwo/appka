<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitbook_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Добавление тренировки"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Отдельный экран для планирования занятия"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Тренер"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/fitbook_surface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/fitbook_stroke"
            app:strokeWidth="1dp">

            <Spinner
                android:id="@+id/spinnerTrainer"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Тип тренировки"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etWorkoutType"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:fontFamily="@font/inter"
                android:hint="Например: Силовая"
                android:inputType="text"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Дата"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDate"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:fontFamily="@font/inter"
                android:hint="ГГГГ-ММ-ДД"
                android:inputType="datetime"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Время"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTime"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:fontFamily="@font/inter"
                android:hint="ЧЧ:ММ"
                android:inputType="datetime"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Длительность (мин)"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDuration"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:fontFamily="@font/inter"
                android:hint="Например: 60"
                android:inputType="number"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Макс. клиентов"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etMaxClients"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:fontFamily="@font/inter"
                android:hint="Например: 12"
                android:inputType="number"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="22dp"
            android:fontFamily="@font/inter"
            android:text="Сохранить"
            android:textAllCaps="false"
            android:textColor="@color/fitbook_text_on_accent"
            android:textStyle="bold"
            app:backgroundTint="@color/fitbook_primary"
            app:cornerRadius="24dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter"
            android:text="Отмена"
            android:textAllCaps="false"
            android:textColor="@color/fitbook_primary"
            android:textStyle="bold"
            app:cornerRadius="24dp"
            app:strokeColor="@color/fitbook_primary"
            app:strokeWidth="1dp" />
    </LinearLayout>
</ScrollView>
