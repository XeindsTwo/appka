<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/fitbook_surface"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        style="@style/TextAppearance.FitBook.DialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Редактирование тренировки" />

    <TextView
        style="@style/TextAppearance.FitBook.DialogSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Обновите параметры занятия" />

    <TextView
        style="@style/TextAppearance.FitBook.DialogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:layout_marginBottom="6dp"
        android:text="Тренер" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/fitbook_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/fitbook_stroke"
        app:strokeWidth="1dp">

        <Spinner
            android:id="@+id/spinnerTrainer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        style="@style/TextAppearance.FitBook.DialogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:text="Тип тренировки" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.FitBook.DarkDialogTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etWorkoutType"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/inter"
            android:hint="Введите тип тренировки"
            android:inputType="text"
            android:minHeight="58dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        style="@style/TextAppearance.FitBook.DialogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:text="Дата" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.FitBook.DarkDialogTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDate"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/inter"
            android:hint="ГГГГ-ММ-ДД"
            android:inputType="none"
            android:minHeight="58dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        style="@style/TextAppearance.FitBook.DialogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:text="Время" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.FitBook.DarkDialogTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:hintEnabled="false">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/etTime"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/inter"
            android:hint="Выберите время"
            android:inputType="none"
            android:minHeight="58dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        style="@style/TextAppearance.FitBook.DialogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:text="Длительность (мин)" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.FitBook.DarkDialogTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDuration"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/inter"
            android:hint="Например: 60"
            android:inputType="number"
            android:minHeight="58dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        style="@style/TextAppearance.FitBook.DialogLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="6dp"
        android:text="Макс. клиентов" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.FitBook.DarkDialogTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMaxClients"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:fontFamily="@font/inter"
            android:hint="Например: 12"
            android:inputType="number"
            android:minHeight="58dp"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint"
            android:textSize="15sp" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="22dp"
        android:fontFamily="@font/inter"
        android:text="Сохранить изменения"
        android:textAllCaps="false"
        android:textColor="@color/fitbook_text_on_accent"
        android:textStyle="bold"
        app:backgroundTint="@color/fitbook_primary"
        app:cornerRadius="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancel"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/inter"
        android:text="Отменить"
        android:textAllCaps="false"
        android:textColor="@color/colorDanger"
        android:textStyle="bold"
        app:cornerRadius="24dp"
        app:strokeColor="@color/colorDanger"
        app:strokeWidth="1dp" />
</LinearLayout>
