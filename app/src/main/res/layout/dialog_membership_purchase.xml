<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:text="@string/client_membership_dialog_title"
        android:textColor="@color/fitbook_text_primary"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPlanInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:lineSpacingExtra="4dp"
        android:paddingBottom="14dp"
        android:text="@string/client_membership_dialog_subtitle"
        android:textColor="@color/fitbook_text_secondary"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:text="@string/client_membership_payment_prompt"
        android:textColor="@color/fitbook_text_secondary"
        android:textSize="11sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        app:boxBackgroundColor="@color/fitbook_background"
        app:boxBackgroundMode="outline"
        app:endIconMode="dropdown_menu"
        app:boxStrokeColor="@color/fitbook_primary"
        app:hintEnabled="false">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actPaymentMethod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:inputType="none"
            android:padding="14dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:text="@string/client_membership_goal_prompt"
        android:textColor="@color/fitbook_text_secondary"
        android:textSize="11sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        app:boxBackgroundColor="@color/fitbook_background"
        app:boxBackgroundMode="outline"
        app:endIconMode="dropdown_menu"
        app:boxStrokeColor="@color/fitbook_primary"
        app:hintEnabled="false">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actGoal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:inputType="none"
            android:padding="14dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:text="@string/client_membership_time_prompt"
        android:textColor="@color/fitbook_text_secondary"
        android:textSize="11sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        app:boxBackgroundColor="@color/fitbook_background"
        app:boxBackgroundMode="outline"
        app:endIconMode="dropdown_menu"
        app:boxStrokeColor="@color/fitbook_primary"
        app:hintEnabled="false">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actTimeSlot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:inputType="none"
            android:padding="14dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:fontFamily="@font/inter"
        android:includeFontPadding="false"
        android:text="@string/client_membership_note_prompt"
        android:textColor="@color/fitbook_text_secondary"
        android:textSize="11sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2dp"
        app:boxBackgroundColor="@color/fitbook_background"
        app:boxBackgroundMode="outline"
        app:boxStrokeColor="@color/fitbook_primary"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:gravity="top"
            android:hint="@string/client_membership_note_hint"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:padding="14dp"
            android:textColor="@color/fitbook_text_primary"
            android:textColorHint="@color/fitbook_text_hint" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
