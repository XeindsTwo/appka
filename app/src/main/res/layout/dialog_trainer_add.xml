<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Добавить тренера"
            android:textColor="@color/fitbook_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Заполните данные сотрудника"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="ФИО тренера"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:autofillHints="name"
                android:fontFamily="@font/inter"
                android:hint="Введите ФИО тренера"
                android:importantForAutofill="yes"
                android:inputType="textPersonName"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Телефон"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:autofillHints="phone"
                android:fontFamily="@font/inter"
                android:hint="Введите телефон"
                android:importantForAutofill="yes"
                android:inputType="phone"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Email"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:autofillHints="emailAddress"
                android:fontFamily="@font/inter"
                android:hint="Введите email"
                android:importantForAutofill="yes"
                android:inputType="textEmailAddress"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Специализация"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:endIconMode="dropdown_menu"
            app:hintEnabled="false">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/etSpecialization"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:fontFamily="@font/inter"
                android:hint="Выберите специализацию"
                android:inputType="text"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="6dp"
            android:fontFamily="@font/inter"
            android:includeFontPadding="false"
            android:text="Опыт (лет)"
            android:textColor="@color/fitbook_text_secondary"
            android:textSize="11sp" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.FitBook.LoginTextInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hintEnabled="false">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etExperience"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:autofillHints="none"
                android:fontFamily="@font/inter"
                android:hint="Введите количество лет"
                android:inputType="number"
                android:minHeight="58dp"
                android:paddingStart="16dp"
                android:paddingTop="8dp"
                android:paddingEnd="16dp"
                android:paddingBottom="8dp"
                android:singleLine="true"
                android:textColor="@color/fitbook_text_primary"
                android:textColorHint="@color/fitbook_text_hint"
                android:textSize="15sp" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</ScrollView>
