<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.FitBook" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/fitbook_primary</item>
        <item name="colorPrimaryDark">@color/fitbook_primary_dark</item>
        <item name="colorSecondary">@color/fitbook_accent</item>
        <item name="colorAccent">@color/fitbook_accent</item>
        <item name="colorOnPrimary">@color/fitbook_text_on_accent</item>
        <item name="colorOnSecondary">@color/fitbook_text_on_accent</item>
        <item name="android:fontFamily">@font/inter</item>
        <item name="fontFamily">@font/inter</item>
        <item name="android:windowBackground">@color/fitbook_background</item>
        <item name="android:statusBarColor">@color/fitbook_background</item>
        <item name="android:navigationBarColor">@color/fitbook_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="materialButtonStyle">@style/Widget.FitBook.Button</item>
        <item name="textInputStyle">@style/Widget.FitBook.TextInputLayout</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.FitBook.MaterialAlertDialog</item>
    </style>

    <style name="Theme.FitBook" parent="Base.Theme.FitBook" />

    <style name="Widget.FitBook.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/fitbook_primary</item>
        <item name="android:textColor">@color/fitbook_text_on_accent</item>
        <item name="iconTint">@color/fitbook_text_on_accent</item>
    </style>

    <style name="Widget.FitBook.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/fitbook_primary</item>
        <item name="hintTextColor">@color/fitbook_primary</item>
    </style>

    <style name="Widget.FitBook.LoginTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/fitbook_surface</item>
        <item name="boxStrokeColor">@color/fitbook_stroke</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintEnabled">false</item>
        <item name="hintTextColor">@color/fitbook_text_secondary</item>
        <item name="startIconTint">@color/fitbook_primary</item>
        <item name="endIconTint">@color/fitbook_primary</item>
        <item name="startIconMinSize">18dp</item>
        <item name="endIconMinSize">18dp</item>
    </style>

    <style name="TextAppearance" />

    <style name="TextAppearance.FitBook" />

    <style name="TextAppearance.FitBook.SectionTitle">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/fitbook_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="TextAppearance.FitBook.HeaderTitle">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/fitbook_text_on_accent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">22sp</item>
    </style>

    <style name="TextAppearance.FitBook.HeaderSubtitle">
        <item name="android:fontFamily">@font/inter</item>
        <item name="android:textColor">@color/fitbook_text_on_accent</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ShapeAppearance.FitBook.DashboardCard" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="ShapeAppearance.FitBook.ProfileAvatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">38dp</item>
    </style>

    <style name="ThemeOverlay.FitBook.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorSurface">@color/fitbook_surface</item>
        <item name="colorOnSurface">@color/fitbook_text_primary</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.FitBook.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.FitBook.DialogTextButton</item>
    </style>

    <style name="Widget.FitBook.DialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/fitbook_primary</item>
    </style>

    <style name="Widget.FitBook.DialogTextButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/fitbook_text_secondary</item>
    </style>
</resources>
