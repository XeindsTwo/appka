<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET" />
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FitBook">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- Admin Activity -->
        <activity
            android:name=".AdminActivity"
            android:exported="false" />

        <activity
            android:name=".AddTrainerActivity"
            android:exported="false" />

        <activity
            android:name=".AddScheduleActivity"
            android:exported="false" />

        <activity
            android:name=".TrainerManagementActivity"
            android:exported="false" />

        <activity
            android:name=".ClientManagementActivity"
            android:exported="false" />

        <activity
            android:name=".MembershipManagementActivity"
            android:exported="false" />

        <!-- Trainer Activity -->
        <activity
            android:name=".TrainerActivity"
            android:exported="false" />

        <!-- Client Activity -->
        <activity
            android:name=".ClientActivity"
            android:exported="false" />

        <activity
            android:name=".ContactsActivity"
            android:exported="false" />

    </application>

</manifest>
